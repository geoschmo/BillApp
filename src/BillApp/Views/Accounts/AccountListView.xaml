<UserControl x:Class="BillApp.Views.Accounts.AccountListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:BillApp.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:AccountListViewModel}"
             d:DesignHeight="600" d:DesignWidth="900">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <DockPanel Grid.Row="0" Margin="0,0,0,15">
            <TextBlock Text="Accounts" FontSize="24" FontWeight="Bold" VerticalAlignment="Center"/>
            <Button Content="+ Add Account"
                    Command="{Binding AddAccountCommand}"
                    HorizontalAlignment="Right"
                    Padding="15,8"
                    Background="#0078D4"
                    Foreground="White"
                    BorderThickness="0"
                    Cursor="Hand"/>
        </DockPanel>

        <!-- Summary Cards -->
        <Border Grid.Row="1" Background="#F5F5F5" Padding="15" Margin="0,0,0,15" CornerRadius="4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Assets -->
                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                    <TextBlock Text="Total Assets" FontSize="12" Foreground="Gray" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding TotalAssets, StringFormat=C}"
                               FontSize="20" FontWeight="Bold" Foreground="#4CAF50" HorizontalAlignment="Center"/>
                </StackPanel>

                <Border Grid.Column="1" Width="1" Background="#E0E0E0" Margin="10,0"/>

                <!-- Liabilities -->
                <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                    <TextBlock Text="Total Liabilities" FontSize="12" Foreground="Gray" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding TotalLiabilities, StringFormat=C}"
                               FontSize="20" FontWeight="Bold" Foreground="#F44336" HorizontalAlignment="Center"/>
                </StackPanel>

                <Border Grid.Column="3" Width="1" Background="#E0E0E0" Margin="10,0"/>

                <!-- Net Worth -->
                <StackPanel Grid.Column="4" HorizontalAlignment="Center">
                    <TextBlock Text="Net Worth" FontSize="12" Foreground="Gray" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding NetWorth, StringFormat=C}"
                               FontSize="20" FontWeight="Bold" Foreground="#0078D4" HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Filters -->
        <Border Grid.Row="2" Background="#F5F5F5" Padding="15" Margin="0,0,0,15" CornerRadius="4">
            <StackPanel Orientation="Horizontal">
                <TextBox Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}"
                         Width="200"
                         Padding="8"
                         VerticalContentAlignment="Center">
                    <TextBox.Style>
                        <Style TargetType="TextBox">
                            <Style.Triggers>
                                <Trigger Property="Text" Value="">
                                    <Setter Property="Background">
                                        <Setter.Value>
                                            <VisualBrush Stretch="None" AlignmentX="Left">
                                                <VisualBrush.Visual>
                                                    <TextBlock Text="Search name or institution..." Foreground="Gray" Margin="8,0,0,0"/>
                                                </VisualBrush.Visual>
                                            </VisualBrush>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </TextBox.Style>
                </TextBox>

                <ComboBox ItemsSource="{Binding AccountTypeOptions}"
                          SelectedItem="{Binding FilterType}"
                          Width="150"
                          Margin="10,0,0,0"
                          Padding="8">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <Button Content="Apply"
                        Command="{Binding ApplyFilterCommand}"
                        Margin="10,0,0,0"
                        Padding="15,8"/>

                <Button Content="Clear"
                        Command="{Binding ClearFilterCommand}"
                        Margin="5,0,0,0"
                        Padding="15,8"/>
            </StackPanel>
        </Border>

        <!-- Accounts DataGrid -->
        <DataGrid x:Name="AccountsDataGrid"
                  Grid.Row="3"
                  ItemsSource="{Binding Accounts}"
                  SelectedItem="{Binding SelectedAccount}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column"
                  BorderThickness="1"
                  BorderBrush="#E0E0E0">

            <DataGrid.Columns>
                <!-- Name -->
                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*" MinWidth="150"/>

                <!-- Type -->
                <DataGridTextColumn Header="Type" Binding="{Binding AccountType}" Width="100"/>

                <!-- Institution -->
                <DataGridTextColumn Header="Institution" Binding="{Binding Institution}" Width="120"/>

                <!-- Balance -->
                <DataGridTextColumn Header="Balance" Binding="{Binding Balance, StringFormat=C}" Width="100">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Right"/>
                            <Setter Property="Padding" Value="5,0"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <!-- Credit Limit (for credit cards) -->
                <DataGridTextColumn Header="Limit" Binding="{Binding CreditLimit, StringFormat=C}" Width="100">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Right"/>
                            <Setter Property="Padding" Value="5,0"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <!-- Interest Rate -->
                <DataGridTextColumn Header="APR" Binding="{Binding InterestRate, StringFormat={}{0:F2}%}" Width="70">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Right"/>
                            <Setter Property="Padding" Value="5,0"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <!-- Active Status -->
                <DataGridTemplateColumn Header="Status" Width="80">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border Padding="5,2" CornerRadius="3" HorizontalAlignment="Left">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="#C8E6C9"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                <Setter Property="Background" Value="#E0E0E0"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock FontSize="12" Foreground="#333333">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="Active"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                    <Setter Property="Text" Value="Closed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Actions -->
                <DataGridTemplateColumn Header="Actions" Width="120">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="Edit"
                                        Command="{Binding DataContext.EditAccountCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}"
                                        Padding="8,4"
                                        Margin="0,0,5,0"
                                        Cursor="Hand"/>

                                <Button Content="Delete"
                                        Command="{Binding DataContext.DeleteAccountCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}"
                                        Padding="8,4"
                                        Foreground="#F44336"
                                        Cursor="Hand"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>

            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsActive}" Value="False">
                            <Setter Property="Opacity" Value="0.6"/>
                        </DataTrigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#E3F2FD"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>
        </DataGrid>

        <!-- Loading indicator -->
        <Border Grid.Row="3"
                Background="#80FFFFFF"
                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
            <TextBlock Text="Loading..."
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       FontSize="16"/>
        </Border>

        <!-- Empty state -->
        <TextBlock Grid.Row="3"
                   Text="No accounts found. Click '+ Add Account' to add your first account."
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Foreground="Gray"
                   FontSize="14">
            <TextBlock.Style>
                <Style TargetType="TextBlock">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding Accounts.Count}" Value="0"/>
                                <Condition Binding="{Binding IsLoading}" Value="False"/>
                            </MultiDataTrigger.Conditions>
                            <Setter Property="Visibility" Value="Visible"/>
                        </MultiDataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>
    </Grid>
</UserControl>
