<UserControl x:Class="BillApp.Views.Accounts.AccountEditView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:BillApp.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:AccountEditViewModel}"
             d:DesignHeight="500" d:DesignWidth="900">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0"
                   Text="{Binding Title}"
                   FontSize="24"
                   FontWeight="Bold"
                   Margin="0,0,0,20"/>

        <!-- Validation Error -->
        <Border Grid.Row="1"
                Background="#FFEBEE"
                Padding="10"
                Margin="0,0,0,15"
                CornerRadius="4"
                Visibility="{Binding ValidationError, Converter={StaticResource NullToVisibilityConverter}}">
            <TextBlock Text="{Binding ValidationError}" Foreground="#C62828"/>
        </Border>

        <!-- Two Column Form -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="30"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left Column - Basic & Financial Info -->
            <StackPanel Grid.Column="0">
                <TextBlock Text="Basic Information" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>

                <!-- Name -->
                <TextBlock Text="Account Name *" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                         Padding="10"
                         Margin="0,0,0,15"/>

                <!-- Type and Institution -->
                <Grid Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Column="0" Grid.Row="0" Text="Account Type" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <ComboBox Grid.Column="0" Grid.Row="1"
                              ItemsSource="{Binding AccountTypeOptions}"
                              SelectedItem="{Binding AccountType}"
                              Padding="10"/>

                    <TextBlock Grid.Column="2" Grid.Row="0" Text="Institution" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <TextBox Grid.Column="2" Grid.Row="1"
                             Text="{Binding Institution, UpdateSourceTrigger=PropertyChanged}"
                             Padding="10"/>
                </Grid>

                <!-- Account Number -->
                <TextBlock Text="Account Number (encrypted)" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <TextBox Text="{Binding AccountNumber, UpdateSourceTrigger=PropertyChanged}"
                         Padding="10"
                         Margin="0,0,0,15"/>

                <TextBlock Text="Financial Information" FontSize="16" FontWeight="SemiBold" Margin="0,10,0,10"/>

                <!-- Balance, Credit Limit, Interest Rate -->
                <Grid Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Column="0" Grid.Row="0" Text="Balance" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <TextBox Grid.Column="0" Grid.Row="1"
                             Text="{Binding Balance, UpdateSourceTrigger=PropertyChanged, StringFormat=F2}"
                             Padding="10"/>

                    <TextBlock Grid.Column="2" Grid.Row="0" Text="Credit Limit" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <TextBox Grid.Column="2" Grid.Row="1"
                             Text="{Binding CreditLimit, UpdateSourceTrigger=PropertyChanged, StringFormat=F2}"
                             Padding="10"/>

                    <TextBlock Grid.Column="4" Grid.Row="0" Text="Interest Rate (%)" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <TextBox Grid.Column="4" Grid.Row="1"
                             Text="{Binding InterestRate, UpdateSourceTrigger=PropertyChanged, StringFormat=F2}"
                             Padding="10"/>
                </Grid>

                <!-- Status -->
                <CheckBox Content="Account is active"
                          IsChecked="{Binding IsActive}"
                          Margin="0,5,0,0"/>
                <CheckBox Content="Use as payment method"
                          IsChecked="{Binding IsPaymentAccount}"
                          Margin="0,10,0,0"
                          ToolTip="Check this to make this account available as a payment method when paying bills"/>
            </StackPanel>

            <!-- Right Column - Credentials & Notes -->
            <StackPanel Grid.Column="2">
                <TextBlock Text="Online Access (encrypted)" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>

                <!-- Login URL -->
                <TextBlock Text="Login URL" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <TextBox Text="{Binding LoginUrl, UpdateSourceTrigger=PropertyChanged}"
                         Padding="10"
                         Margin="0,0,0,15"/>

                <!-- Username and Password -->
                <Grid Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Column="0" Grid.Row="0" Text="Username" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <TextBox Grid.Column="0" Grid.Row="1"
                             Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                             Padding="10"/>

                    <TextBlock Grid.Column="2" Grid.Row="0" Text="Password" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <TextBox Grid.Column="2" Grid.Row="1"
                             Text="{Binding Password, UpdateSourceTrigger=PropertyChanged}"
                             Padding="10"/>
                </Grid>

                <TextBlock Text="Notes" FontSize="16" FontWeight="SemiBold" Margin="0,10,0,10"/>

                <!-- Notes -->
                <TextBox Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"
                         Padding="10"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         Height="150"
                         VerticalScrollBarVisibility="Auto"/>
            </StackPanel>
        </Grid>

        <!-- Action Buttons -->
        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,20,0,0">
            <Button Content="Cancel"
                    Command="{Binding CancelCommand}"
                    Padding="20,10"
                    Margin="0,0,10,0"
                    MinWidth="100"/>

            <Button Content="Save"
                    Command="{Binding SaveCommand}"
                    Padding="20,10"
                    MinWidth="100"
                    Background="#0078D4"
                    Foreground="White"
                    BorderThickness="0"/>
        </StackPanel>

        <!-- Loading overlay -->
        <Border Grid.RowSpan="4"
                Background="#80FFFFFF"
                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
            <TextBlock Text="Loading..."
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       FontSize="16"/>
        </Border>
    </Grid>
</UserControl>
