<UserControl x:Class="BillApp.Views.Bills.BillEditView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:BillApp.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:BillEditViewModel}"
             d:DesignHeight="500" d:DesignWidth="900">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0"
                   Text="{Binding Title}"
                   FontSize="24"
                   FontWeight="Bold"
                   Margin="0,0,0,20"/>

        <!-- Validation Error -->
        <Border Grid.Row="1"
                Background="#FFEBEE"
                Padding="10"
                Margin="0,0,0,15"
                CornerRadius="4"
                Visibility="{Binding ValidationError, Converter={StaticResource NullToVisibilityConverter}}">
            <TextBlock Text="{Binding ValidationError}" Foreground="#C62828"/>
        </Border>

        <!-- Two Column Form -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="30"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left Column -->
            <StackPanel Grid.Column="0">
                <!-- Payee -->
                <TextBlock Text="Payee *" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <TextBox Text="{Binding Payee, UpdateSourceTrigger=PropertyChanged}"
                         Padding="10"
                         Margin="0,0,0,15"/>

                <!-- Amount Fields -->
                <Grid Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Column="0" Grid.Row="0" Text="Amount Due" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <TextBox Grid.Column="0" Grid.Row="1"
                             Text="{Binding AmountDue, UpdateSourceTrigger=PropertyChanged, StringFormat=F2}"
                             Padding="10"/>

                    <TextBlock Grid.Column="2" Grid.Row="0" Text="Amount Paid" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <TextBox Grid.Column="2" Grid.Row="1"
                             Text="{Binding AmountPaid, UpdateSourceTrigger=PropertyChanged, StringFormat=F2}"
                             Padding="10"/>

                    <TextBlock Grid.Column="4" Grid.Row="0" Text="Balance" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <TextBox Grid.Column="4" Grid.Row="1"
                             Text="{Binding Balance, UpdateSourceTrigger=PropertyChanged, StringFormat=F2}"
                             Padding="10"/>
                </Grid>

                <!-- Due Date and Paid Date -->
                <Grid Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Column="0" Grid.Row="0" Text="Due Date" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <DatePicker Grid.Column="0" Grid.Row="1"
                                SelectedDate="{Binding DueDate}"
                                Padding="10"/>

                    <TextBlock Grid.Column="2" Grid.Row="0" Text="Paid Date" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <DatePicker Grid.Column="2" Grid.Row="1"
                                SelectedDate="{Binding PaidDate}"
                                Padding="10"/>
                </Grid>

                <!-- Category and Status -->
                <Grid Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Column="0" Grid.Row="0" Text="Category" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <ComboBox Grid.Column="0" Grid.Row="1"
                              ItemsSource="{Binding Categories}"
                              SelectedValue="{Binding CategoryId}"
                              SelectedValuePath="Id"
                              DisplayMemberPath="Name"
                              Padding="10"/>

                    <TextBlock Grid.Column="2" Grid.Row="0" Text="Status" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <ComboBox Grid.Column="2" Grid.Row="1"
                              ItemsSource="{Binding StatusOptions}"
                              SelectedItem="{Binding Status}"
                              Padding="10"/>
                </Grid>
            </StackPanel>

            <!-- Right Column -->
            <StackPanel Grid.Column="2">
                <!-- Recurrence and Payment Account -->
                <Grid Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Column="0" Grid.Row="0" Text="Recurrence" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <ComboBox Grid.Column="0" Grid.Row="1"
                              ItemsSource="{Binding FrequencyOptions}"
                              SelectedItem="{Binding Frequency}"
                              Padding="10"/>

                    <TextBlock Grid.Column="2" Grid.Row="0" Text="Payment Account" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <ComboBox Grid.Column="2" Grid.Row="1"
                              ItemsSource="{Binding Accounts}"
                              SelectedValue="{Binding AccountId}"
                              SelectedValuePath="Id"
                              DisplayMemberPath="Name"
                              Padding="10"/>
                </Grid>

                <!-- Payment URL -->
                <TextBlock Text="Payment URL" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <TextBox Text="{Binding PaymentUrl, UpdateSourceTrigger=PropertyChanged}"
                         Padding="10"
                         Margin="0,0,0,15"/>

                <!-- Account Number -->
                <TextBlock Text="Account/Reference Number" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <TextBox Text="{Binding AccountNumber, UpdateSourceTrigger=PropertyChanged}"
                         Padding="10"
                         Margin="0,0,0,15"/>

                <!-- Notes -->
                <TextBlock Text="Notes" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <TextBox Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"
                         Padding="10"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         Height="100"
                         VerticalScrollBarVisibility="Auto"/>
            </StackPanel>
        </Grid>

        <!-- Action Buttons -->
        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,20,0,0">
            <Button Content="Cancel"
                    Command="{Binding CancelCommand}"
                    Padding="20,10"
                    Margin="0,0,10,0"
                    MinWidth="100"/>

            <Button Content="Save"
                    Command="{Binding SaveCommand}"
                    Padding="20,10"
                    MinWidth="100"
                    Background="#0078D4"
                    Foreground="White"
                    BorderThickness="0"/>
        </StackPanel>

        <!-- Loading overlay -->
        <Border Grid.RowSpan="4"
                Background="#80FFFFFF"
                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
            <TextBlock Text="Loading..."
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       FontSize="16"/>
        </Border>
    </Grid>
</UserControl>
