<UserControl x:Class="BillApp.Views.Investments.InvestmentsOverviewView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:BillApp.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:InvestmentsOverviewViewModel}"
             d:DesignHeight="700"
             d:DesignWidth="1100">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,15">
            <StackPanel DockPanel.Dock="Left">
                <TextBlock Text="Investments"
                           FontSize="24"
                           FontWeight="Bold"
                           VerticalAlignment="Center"/>
                <TextBlock Text="Current account totals and changes over time."
                           Margin="0,4,0,0"
                           Foreground="#666666"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Upload Snapshot"
                        Command="{Binding QuickImportCommand}"
                        Padding="15,8"
                        Margin="0,0,10,0"
                        Background="#0078D4"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"/>
                <Button Content="Refresh"
                        Command="{Binding LoadSnapshotsCommand}"
                        Padding="15,8"
                        Cursor="Hand"/>
            </StackPanel>
        </DockPanel>

        <Border Grid.Row="1"
                Background="#F5F5F5"
                Padding="15"
                Margin="0,0,0,15"
                CornerRadius="4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Status" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding StatusMessage}"
                               Margin="0,4,0,0"
                               Foreground="#555555"
                               TextWrapping="Wrap"/>
                </StackPanel>

                <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                    <TextBlock Text="Accounts" FontWeight="SemiBold" HorizontalAlignment="Right"/>
                    <TextBlock Text="{Binding AccountSummaries.Count}"
                               Margin="0,4,0,0"
                               FontSize="20"
                               HorizontalAlignment="Right"/>
                </StackPanel>

                <StackPanel Grid.Column="2" HorizontalAlignment="Right">
                    <TextBlock Text="Current Total" FontWeight="SemiBold" HorizontalAlignment="Right"/>
                    <TextBlock Text="{Binding TotalCurrentValue, StringFormat={}{0:C2}}"
                               Margin="0,4,0,0"
                               FontSize="20"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Right"/>
                </StackPanel>
            </Grid>
        </Border>

        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding AccountSummaries}"
                  SelectedItem="{Binding SelectedAccount}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  CanUserSortColumns="True"
                  GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column"
                  BorderThickness="1"
                  BorderBrush="#E0E0E0">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Account"
                                    Binding="{Binding AccountName}"
                                    Width="*"
                                    MinWidth="180"/>
                <DataGridTextColumn Header="Current"
                                    Binding="{Binding CurrentValue, StringFormat={}{0:C2}}"
                                    Width="130">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Right"/>
                            <Setter Property="Padding" Value="5,0"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Previous"
                                    Binding="{Binding PreviousValue, StringFormat={}{0:C2}}"
                                    Width="130">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Right"/>
                            <Setter Property="Padding" Value="5,0"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Change"
                                    Binding="{Binding Change, StringFormat={}{0:C2}}"
                                    Width="120">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Right"/>
                            <Setter Property="Padding" Value="5,0"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Change %"
                                    Binding="{Binding ChangePercent, StringFormat={}{0:P2}}"
                                    Width="100">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Right"/>
                            <Setter Property="Padding" Value="5,0"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
            </DataGrid.Columns>

            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#E3F2FD"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>
        </DataGrid>

        <Expander Grid.Row="3"
                  Header="Snapshot and selected account details"
                  IsExpanded="False"
                  Margin="0,15,0,0">
            <Grid Margin="0,10,0,0" MaxHeight="320">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="3*"/>
                </Grid.ColumnDefinitions>

                <DataGrid Grid.Row="0"
                          Grid.Column="0"
                          ItemsSource="{Binding AccountHistory}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          GridLinesVisibility="Horizontal"
                          HeadersVisibility="Column"
                          BorderThickness="1"
                          BorderBrush="#E0E0E0"
                          Margin="0,0,8,8">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Imported"
                                            Binding="{Binding ImportedAt, StringFormat={}{0:g}}"
                                            Width="140"/>
                        <DataGridTextColumn Header="Value"
                                            Binding="{Binding TotalValue, StringFormat={}{0:C2}}"
                                            Width="110"/>
                        <DataGridTextColumn Header="Change"
                                            Binding="{Binding Change, StringFormat={}{0:C2}}"
                                            Width="100"/>
                        <DataGridTextColumn Header="%"
                                            Binding="{Binding ChangePercent, StringFormat={}{0:P2}}"
                                            Width="80"/>
                    </DataGrid.Columns>
                </DataGrid>

                <DataGrid Grid.Row="0"
                          Grid.Column="1"
                          ItemsSource="{Binding CurrentAccountHoldings}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          GridLinesVisibility="Horizontal"
                          HeadersVisibility="Column"
                          BorderThickness="1"
                          BorderBrush="#E0E0E0"
                          Margin="0,0,0,8">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Symbol"
                                            Binding="{Binding Symbol}"
                                            Width="80"/>
                        <DataGridTextColumn Header="Description"
                                            Binding="{Binding Description}"
                                            Width="*"/>
                        <DataGridTextColumn Header="Market Value"
                                            Binding="{Binding MarketValue, StringFormat={}{0:C2}}"
                                            Width="120"/>
                        <DataGridTextColumn Header="Asset Class"
                                            Binding="{Binding AssetClass}"
                                            Width="120"/>
                    </DataGrid.Columns>
                </DataGrid>

                <DataGrid Grid.Row="1"
                          Grid.ColumnSpan="2"
                          ItemsSource="{Binding Snapshots}"
                          SelectedItem="{Binding SelectedSnapshot}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          GridLinesVisibility="Horizontal"
                          HeadersVisibility="Column"
                          BorderThickness="1"
                          BorderBrush="#E0E0E0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Imported"
                                            Binding="{Binding ImportedAt, StringFormat={}{0:g}}"
                                            Width="160"/>
                        <DataGridTextColumn Header="Source"
                                            Binding="{Binding SourceName}"
                                            Width="180"/>
                        <DataGridTextColumn Header="Notes"
                                            Binding="{Binding Notes}"
                                            Width="*"/>
                        <DataGridTextColumn Header="Holdings"
                                            Binding="{Binding Holdings.Count}"
                                            Width="90"/>
                        <DataGridTextColumn Header="Total Value"
                                            Binding="{Binding TotalValue, StringFormat={}{0:C2}}"
                                            Width="120"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Expander>
    </Grid>
</UserControl>
