<UserControl x:Class="BillApp.Views.Investments.InvestmentsOverviewView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:BillApp.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:InvestmentsOverviewViewModel}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="2*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel>
                <TextBlock Text="Investments"
                           FontSize="22"
                           FontWeight="SemiBold"/>
                <TextBlock Text="Current investment snapshots stored in the database."
                           Margin="0,4,0,0"
                           Foreground="#666666"/>
            </StackPanel>

            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        VerticalAlignment="Center">
                <Button Content="Add Data"
                        Command="{Binding QuickImportCommand}"
                        Padding="16,8"
                        Margin="0,0,8,0"/>
                <Button Content="Refresh"
                        Command="{Binding LoadSnapshotsCommand}"
                        Padding="16,8"/>
            </StackPanel>
        </Grid>

        <Border Grid.Row="1"
                Margin="0,0,0,16"
                Padding="12"
                Background="#F8F8F8"
                BorderBrush="#DDDDDD"
                BorderThickness="1"
                CornerRadius="4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Status"
                               FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding StatusMessage}"
                               Margin="0,4,0,0"
                               TextWrapping="Wrap"/>
                </StackPanel>

                <StackPanel Grid.Column="1">
                    <TextBlock Text="Snapshots"
                               FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding Snapshots.Count}"
                               Margin="0,4,0,0"
                               FontSize="18"/>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="Selected Total"
                               FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding SelectedSnapshotTotal, StringFormat={}{0:C2}}"
                               Margin="0,4,0,0"
                               FontSize="18"/>
                </StackPanel>
            </Grid>
        </Border>

        <GroupBox Grid.Row="2" Header="Snapshots" Margin="0,0,0,16">
            <DataGrid ItemsSource="{Binding Snapshots}"
                      SelectedItem="{Binding SelectedSnapshot}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      Margin="0,8,0,0">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Imported"
                                        Binding="{Binding ImportedAt, StringFormat={}{0:g}}"
                                        Width="160"/>
                    <DataGridTextColumn Header="Source"
                                        Binding="{Binding SourceName}"
                                        Width="180"/>
                    <DataGridTextColumn Header="Notes"
                                        Binding="{Binding Notes}"
                                        Width="2*"/>
                    <DataGridTextColumn Header="Holdings"
                                        Binding="{Binding Holdings.Count}"
                                        Width="90"/>
                    <DataGridTextColumn Header="Total Value"
                                        Binding="{Binding TotalValue, StringFormat={}{0:C2}}"
                                        Width="120"/>
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>

        <GroupBox Grid.Row="3" Header="Holdings In Selected Snapshot">
            <DataGrid ItemsSource="{Binding SnapshotHoldings}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      Margin="0,8,0,0">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Account"
                                        Binding="{Binding AccountName}"
                                        Width="170"/>
                    <DataGridTextColumn Header="Symbol"
                                        Binding="{Binding Symbol}"
                                        Width="100"/>
                    <DataGridTextColumn Header="Description"
                                        Binding="{Binding Description}"
                                        Width="2*"/>
                    <DataGridTextColumn Header="Quantity"
                                        Binding="{Binding Quantity, StringFormat={}{0:N4}}"
                                        Width="100"/>
                    <DataGridTextColumn Header="Price"
                                        Binding="{Binding Price, StringFormat={}{0:C2}}"
                                        Width="100"/>
                    <DataGridTextColumn Header="Market Value"
                                        Binding="{Binding MarketValue, StringFormat={}{0:C2}}"
                                        Width="120"/>
                    <DataGridTextColumn Header="Asset Class"
                                        Binding="{Binding AssetClass}"
                                        Width="140"/>
                    <DataGridTextColumn Header="% Account"
                                        Binding="{Binding PercentOfAccount, StringFormat={}{0:P2}}"
                                        Width="100"/>
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>
    </Grid>
</UserControl>
