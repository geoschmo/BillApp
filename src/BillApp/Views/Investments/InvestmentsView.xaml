<UserControl x:Class="BillApp.Views.Investments.InvestmentsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:BillApp.ViewModels"
             xmlns:local="clr-namespace:BillApp.Views.Investments"
             xmlns:converters="clr-namespace:BillApp.Converters"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:InvestmentsViewModel}">

<Grid Margin="20">
    <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="*"/>
        <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>
        <GroupBox Header="Import Investments">
            <StackPanel Margin="0,0,0,10">
                <TextBlock Text="Account Name"
                           FontWeight="SemiBold"
                           Margin="0,0,0,4"/>
                <TextBox Text="{Binding AccountName, UpdateSourceTrigger=PropertyChanged}"
                         Padding="8,6"
                         Margin="0,0,0,12"/>

                <TextBlock Text="Paste raw investment text"
                           FontWeight="SemiBold"
                           Margin="0,0,0,4"/>
                <TextBox AcceptsReturn="True"
                         TextWrapping="Wrap"
                         Height="150"
                         Text="{Binding RawText, UpdateSourceTrigger=PropertyChanged}"
                         VerticalScrollBarVisibility="Auto"
                         Padding="8,6"/>

                <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                    <Button Content="Parse Text"
                            Command="{Binding ParseTextCommand}"
                            Padding="16,6"
                            IsEnabled="{Binding IsParsing, Converter={StaticResource InverseBoolConverter}}"/>
                    <Button Content="Load CSV"
                            Command="{Binding LoadCsvCommand}"
                            Padding="16,6"
                            Margin="10,0,0,0"
                            IsEnabled="{Binding IsParsing, Converter={StaticResource InverseBoolConverter}}"/>
                    <TextBlock Text="Parsing..."
                               Foreground="Gray"
                               Margin="10,0,0,0"
                               VerticalAlignment="Center"
                               Visibility="{Binding IsParsing, Converter={StaticResource BoolToVisibilityConverter}}"/>
                </StackPanel>

                <TextBlock Text="{Binding SelectedCsvPath}"
                           Foreground="Gray"
                           FontSize="11"
                           Margin="0,6,0,0"
                           TextTrimming="CharacterEllipsis"/>

                <ItemsControl ItemsSource="{Binding Warnings}"
                              Margin="0,8,0,0">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="•"
                                           FontWeight="Bold"
                                           Foreground="#C62828"
                                           Margin="0,0,4,0"/>
                                <TextBlock Text="{Binding}"
                                           Foreground="#C62828"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </GroupBox>

        <GroupBox Header="Preview holdings" Grid.Row="1" Margin="0,16,0,0">
            <StackPanel>
                <TextBlock Text="{Binding TotalValue, StringFormat='Total value: {0:C2}'}"
                           FontWeight="SemiBold"
                           Margin="0,0,0,10"/>
                <DataGrid ItemsSource="{Binding PreviewHoldings}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          MaxHeight="340"
                          ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Account"
                                            Binding="{Binding AccountName}"/>
                        <DataGridTextColumn Header="Symbol"
                                            Binding="{Binding Symbol}"/>
                        <DataGridTextColumn Header="Description"
                                            Binding="{Binding Description}"
                                            Width="2*"/>
                        <DataGridTextColumn Header="Qty"
                                            Binding="{Binding Quantity, StringFormat={}{0:N4}}"/>
                        <DataGridTextColumn Header="Price"
                                            Binding="{Binding Price, StringFormat={}{0:C2}}"/>
                        <DataGridTextColumn Header="Market Value"
                                            Binding="{Binding MarketValue, StringFormat={}{0:C2}}"/>
                        <DataGridTextColumn Header="Asset Class"
                                            Binding="{Binding AssetClass}"/>
                    </DataGrid.Columns>
                </DataGrid>
            </StackPanel>
        </GroupBox>

        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Grid.Row="2"
                    Margin="0,20,0,0">
            <Button Content="Commit Import"
                    Command="{Binding CommitImportCommand}"
                    Padding="20,8"
                    IsEnabled="{Binding IsImporting, Converter={StaticResource InverseBoolConverter}}"/>
            <TextBlock Text="{Binding StatusMessage}"
                       VerticalAlignment="Center"
                       Margin="10,0,0,0"
                       Foreground="Gray"/>
        </StackPanel>
    </Grid>
</UserControl>
