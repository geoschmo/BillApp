<Window x:Class="BillApp.Views.Dialogs.RestoreConfirmationDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Confirm Restore"
        Width="450"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Warning Icon and Message -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
            <TextBlock Text="&#x26A0;"
                       FontSize="24"
                       Foreground="Orange"
                       VerticalAlignment="Center"
                       Margin="0,0,10,0"/>
            <TextBlock Text="Warning: Restoring will replace all current data!"
                       FontWeight="Bold"
                       FontSize="14"
                       Foreground="DarkOrange"
                       VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Backup Info -->
        <Border Grid.Row="1"
                Background="#F5F5F5"
                BorderBrush="#DDDDDD"
                BorderThickness="1"
                CornerRadius="4"
                Padding="15"
                Margin="0,0,0,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Backup Created:" FontWeight="SemiBold" Margin="0,0,15,5"/>
                <TextBlock Grid.Row="0" Grid.Column="1" x:Name="CreatedAtText" Margin="0,0,0,5"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="App Version:" FontWeight="SemiBold" Margin="0,0,15,5"/>
                <TextBlock Grid.Row="1" Grid.Column="1" x:Name="AppVersionText" Margin="0,0,0,5"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Bills:" FontWeight="SemiBold" Margin="0,0,15,5"/>
                <TextBlock Grid.Row="2" Grid.Column="1" x:Name="BillsCountText" Margin="0,0,0,5"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="Accounts:" FontWeight="SemiBold" Margin="0,0,15,5"/>
                <TextBlock Grid.Row="3" Grid.Column="1" x:Name="AccountsCountText" Margin="0,0,0,5"/>

                <TextBlock Grid.Row="4" Grid.Column="0" Text="Categories:" FontWeight="SemiBold" Margin="0,0,15,0"/>
                <TextBlock Grid.Row="4" Grid.Column="1" x:Name="CategoriesCountText"/>
            </Grid>
        </Border>

        <!-- Confirmation Message -->
        <TextBlock Grid.Row="2"
                   TextWrapping="Wrap"
                   Margin="0,0,0,15">
            <Run Text="All existing bills, accounts, and categories will be "/>
            <Run Text="permanently deleted" FontWeight="Bold"/>
            <Run Text=" and replaced with the backup data. This cannot be undone."/>
        </TextBlock>

        <!-- Buttons -->
        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,10,0,0">
            <Button Content="Restore"
                    Width="80"
                    Padding="8,6"
                    Margin="0,0,10,0"
                    Background="#E57373"
                    Foreground="White"
                    Click="RestoreButton_Click"/>
            <Button Content="Cancel"
                    Width="80"
                    Padding="8,6"
                    IsCancel="True"
                    Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
