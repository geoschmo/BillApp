<Window x:Class="BillApp.Views.Dialogs.DatabaseSetupDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Welcome to BillApp"
        Width="450"
        SizeToContent="Height"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        ShowInTaskbar="True">

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0"
                   Text="Welcome to BillApp!"
                   FontSize="22"
                   FontWeight="Bold"
                   Margin="0,0,0,10"/>

        <TextBlock Grid.Row="1"
                   Text="No database was found. How would you like to get started?"
                   TextWrapping="Wrap"
                   Foreground="Gray"
                   Margin="0,0,0,25"/>

        <!-- Option 1: Empty Database -->
        <Border Grid.Row="2"
                BorderBrush="#DDDDDD"
                BorderThickness="1"
                CornerRadius="4"
                Padding="15"
                Margin="0,0,0,10"
                Cursor="Hand"
                MouseLeftButtonUp="EmptyDatabase_Click"
                Background="White">
            <Border.Style>
                <Style TargetType="Border">
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#F5F5F5"/>
                            <Setter Property="BorderBrush" Value="#4CAF50"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Start Fresh"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Margin="0,0,0,5"/>
                    <TextBlock Text="Create an empty database. Best if you're ready to enter your own bills and accounts."
                               TextWrapping="Wrap"
                               Foreground="Gray"
                               FontSize="12"/>
                </StackPanel>
                <TextBlock Grid.Column="1"
                           Text=">"
                           FontSize="20"
                           VerticalAlignment="Center"
                           Foreground="Gray"
                           Margin="15,0,0,0"/>
            </Grid>
        </Border>

        <!-- Option 2: Sample Data -->
        <Border Grid.Row="3"
                BorderBrush="#DDDDDD"
                BorderThickness="1"
                CornerRadius="4"
                Padding="15"
                Margin="0,0,0,20"
                Cursor="Hand"
                MouseLeftButtonUp="SampleData_Click"
                Background="White">
            <Border.Style>
                <Style TargetType="Border">
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#F5F5F5"/>
                            <Setter Property="BorderBrush" Value="#2196F3"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Try with Sample Data"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Margin="0,0,0,5"/>
                    <TextBlock Text="Load example accounts and bills to explore the app. You can delete this data anytime."
                               TextWrapping="Wrap"
                               Foreground="Gray"
                               FontSize="12"/>
                </StackPanel>
                <TextBlock Grid.Column="1"
                           Text=">"
                           FontSize="20"
                           VerticalAlignment="Center"
                           Foreground="Gray"
                           Margin="15,0,0,0"/>
            </Grid>
        </Border>

        <!-- Footer hint -->
        <TextBlock Grid.Row="4"
                   Text="Your data is stored locally and encrypted on your computer."
                   FontSize="11"
                   Foreground="Gray"
                   HorizontalAlignment="Center"/>
    </Grid>
</Window>
